};

// ---- 12. ФУНКЦИИ ----
// Функция без параметров
fn simple() -> void {
    return;
}

// Функция с параметрами
fn add(int a, int b) -> int {
    return a + b;
}

// Рекурсивная функция
fn factorial(int n) -> int {
    if (n <= 1) {
        return 1;
    }
    return n * factorial(n - 1);
}

// ---- 13. УПРАВЛЯЮЩИЕ КОНСТРУКЦИИ ----
// if-else
if (x > 0) {
    y = 1;
} else {
    y = -1;
}

// вложенный if
if (x > 0) {
    if (x > 10) {
        y = 2;
    } else {
        y = 1;
    }
} else {
    y = 0;
}

// while цикл
while (i < 10) {
    i = i + 1;
}

// for цикл
for (int i = 0; i < 10; i = i + 1) {
    sum = sum + i;
}

