// Тест массивов
fn test_array() -> int {
    int arr[5];
    arr[0] = 42;
    return arr[0];
}

// Тест структур
struct Point {
    int x;
    int y;
}

fn test_struct() -> int {
    Point p;
    p.x = 10;
    p.y = 20;
    return p.x + p.y;
}

// Тест float сравнений
fn test_float() -> int {
    float a = 3.14;
    float b = 2.71;
    if (a > b) {
        return 1;
    }
    return 0;
}

fn main() -> int {
    return test_array() + test_struct() + test_float();
}