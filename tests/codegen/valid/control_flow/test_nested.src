// test_nested.src
// Тест вложенных циклов и условий

fn main() -> int {
    int sum = 0;

    for (int i = 0; i < 5; i = i + 1) {
        for (int j = 0; j < 3; j = j + 1) {
            if (i == j) {
                sum = sum + i * j;
            }
        }
    }

    // sum = 0*0 + 1*1 + 2*2 = 0 + 1 + 4 = 5
    return sum;  // Ожидается: 5
}