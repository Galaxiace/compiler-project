// test_complex.src
// Комплексное выражение с приоритетами

fn main() -> int {
    int a = 10;
    int b = 5;
    int c = 3;
    int d = 2;

    // result = (a + b) * (c - d) / (a % b)
    // (10+5)=15 * (3-2)=1 = 15 / (10%5=0) -> деление на ноль! используем другой пример
    int result = (a + b) * (c - d) / (a / b);
    // (15) * (1) / (2) = 15 / 2 = 7 (целочисленное деление)

    return result;  // Ожидается: 7
}